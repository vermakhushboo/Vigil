postgres_data/
es_data/
prometheus_data/
chroma_db/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Audio files (generated by ElevenLabs)
static/audio/*.mp3
static/audio/*.wav

# Logs
*.log
