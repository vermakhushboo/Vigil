# ─── Vigil ─── Autonomous Incident Response Agent
# Copy this file to .env and fill in your values

# ─── App ───
PORT=8000
APP_BASE_URL=http://localhost:8000

# ─── PostgreSQL ───
POSTGRES_DB=vigil
POSTGRES_USER=vigil
POSTGRES_PASSWORD=vigil_pass

# ─── Elasticsearch ───
ELASTICSEARCH_URL=http://localhost:9200

# ─── Mistral (Phase 2) ───
MISTRAL_API_KEY=

# ─── ElevenLabs (Phase 4) ───
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Twilio (Phase 4) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ONCALL_PHONE_NUMBER=

# ─── Vapi (Phase 5) ───
VAPI_API_KEY=
VAPI_ASSISTANT_ID=695c69a2-d6d8-4822-80a8-9b737381d580
VAPI_PHONE_NUMBER_ID=

# ─── GitHub (Phase 2, optional) ───
GITHUB_TOKEN=
GITHUB_REPO=
